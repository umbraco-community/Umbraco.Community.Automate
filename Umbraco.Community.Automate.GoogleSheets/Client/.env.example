# Copy to .env (gitignored) and adjust if your local Demo site differs.
# Requires the Demo site running with AUTOMATE_E2E_MODE=1.
# Note: `URL` (not UMBRACO_URL) is what @umbraco/playwright-testhelpers itself reads.
URL=https://localhost:44343
UMBRACO_USER_LOGIN=admin@example.com
UMBRACO_USER_PASSWORD=password1234
